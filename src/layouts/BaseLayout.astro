---
import { GIVEBUTTER_ACCOUNT_ID, GIVEBUTTER_NEWSLETTER_WIDGET_ID } from '../lib/givebutter';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object;
}

const {
  title,
  description = 'Enable the community to repair and create through educational skill building workshops and access to tools.',
  image = '/images/meta-image.jpg',
  type = 'website',
  jsonLd
} = Astro.props;

const siteOrigin = import.meta.env.DEV ? Astro.url.origin : Astro.site;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('The Ned Workshop') ? title : `${title} | The Ned Workshop`;
const ogImage = image.startsWith('http') ? image : new URL(image, siteOrigin).toString();

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "The Ned Workshop",
  "description": "Enable the community to repair and create through educational skill building workshops and access to tools.",
  "url": "https://nedworkshop.org",
  "logo": "https://nedworkshop.org/favicon.svg",
  "email": "info@nedworkshop.org",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nederland",
    "addressRegion": "CO",
    "addressCountry": "US"
  },
  "sameAs": []
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="The Ned Workshop" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Caprasimo&display=swap"
    />

    <title>{fullTitle}</title>

    {GIVEBUTTER_ACCOUNT_ID && (
      <script
        is:inline
        defer
        src={`https://widgets.givebutter.com/latest.umd.cjs?acct=${GIVEBUTTER_ACCOUNT_ID}&p=other`}
      />
    )}

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white/80 backdrop-blur-md border-b-2 border-amber-200 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="group">
            <span class="text-2xl font-extrabold text-amber-600 group-hover:text-amber-700 transition-colors duration-300">
              The Ned Workshop
            </span>
          </a>
          <div class="flex items-center gap-6">
            <a href="/" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Home
            </a>
            <a href="/events" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Events
            </a>
            <a href="/tools" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Tool Library
            </a>
            <a href="/about" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              About
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-white/80 backdrop-blur-md border-t-2 border-amber-200 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-8">
        {GIVEBUTTER_NEWSLETTER_WIDGET_ID && (
          <div class="max-w-md mx-auto mb-8 text-center">
            <h2 class="text-xl font-extrabold text-amber-700 mb-3">
              Stay in the loop
            </h2>
            <givebutter-widget id={GIVEBUTTER_NEWSLETTER_WIDGET_ID}></givebutter-widget>
          </div>
        )}
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-stone-500 text-sm font-semibold">
            &copy; {new Date().getFullYear()} The Ned Workshop
          </p>
          <p class="text-lg font-bold text-amber-600">
            Create, play, make, learn&mdash;together.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
