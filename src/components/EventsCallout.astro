---
// Temporary callout shown above the upcoming-events list.
// Edit or remove this component to change/remove the message in all
// the places it appears (home page, events page, etc.).
---

<div
  role="note"
  class="mb-6 flex items-start gap-3 rounded-r-xl border-l-4 border-amber-500 bg-amber-50/90 px-5 py-4 shadow-sm"
>
  <svg
    class="w-6 h-6 text-amber-600 flex-shrink-0 mt-0.5"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path d="m3 11 18-5v12L3 14v-3z" />
    <path d="M11.6 16.8a3 3 0 1 1-5.8-1.6" />
  </svg>
  <p class="text-stone-700 font-medium">
    <span class="font-bold text-amber-800">Heads up &mdash;</span>
    see you this summer at the Nederland Farmer&rsquo;s Market. Details to come soon!
  </p>
</div>
