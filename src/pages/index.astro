---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEvents, formatEventDate } from '../lib/events';
import { getCreations } from '../lib/creations';

const events = await getEvents();
const now = new Date();
const upcomingEvents = events.filter(e => e.date >= now);

const creations = await getCreations();

function formatCreationDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}
---

<BaseLayout title="The Ned Workshop — Tool Library & Workshops in Nederland, CO">
  <!-- Hero Section -->
  <section class="bg-amber-50">
    <h1 class="sr-only">The Ned Workshop &mdash; Community Tool Library &amp; Skill-Building Workshops in Nederland, Colorado</h1>
    <img
      src="/images/hero.webp"
      alt="The Ned Workshop"
      width="2000"
      height="898"
      fetchpriority="high"
      class="w-full h-auto block"
    />
    <div class="max-w-5xl mx-auto px-6 py-16">
      <p
        class="text-center text-5xl md:text-6xl text-amber-600 tracking-[0.15em] pl-[0.15em]"
        style="font-family: 'Caprasimo', serif;"
      ><span aria-hidden="true" class="text-amber-500 mr-4">★</span>HOWDY<span aria-hidden="true" class="text-amber-500 ml-4">★</span></p>
      <p class="text-center mt-4 text-xl md:text-2xl text-stone-600 font-semibold">
        Create, play, make, learn&mdash;together.
      </p>
    </div>
  </section>

  <!-- Upcoming Events Section -->
  <section class="bg-amber-100 py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-2 text-amber-700">
        Upcoming Events
      </h2>
      <p class="text-stone-600 font-medium mb-6">
        See you this summer at the Nederland Farmer's Market. Details to come soon!
      </p>
      <div class="space-y-6">
        {upcomingEvents.length > 0 ? (
          upcomingEvents.map((event) => (
            <a href={`/events/${event.slug}`} class="block bg-white/80 rounded-2xl p-6 border border-amber-200 hover:border-amber-400 hover:shadow-lg transition-all duration-300 group">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
                <h3 class="text-2xl font-bold text-amber-700 group-hover:text-amber-800">{event.title}</h3>
                <div class="md:text-right">
                  <p class="text-lg font-bold text-amber-600">{formatEventDate(event.date)}</p>
                  <p class="text-stone-600 font-medium">{event.startTime} - {event.endTime}</p>
                </div>
              </div>
              <div class={event.image ? "flex flex-col md:flex-row gap-4" : ""}>
                {event.image && (
                  <img src={event.image.replace(/^\/public/, '')} alt={event.title} class="rounded-xl w-32 h-32 object-cover border border-amber-200 flex-shrink-0" width="128" height="128" loading="lazy" />
                )}
                <div class="space-y-3 text-stone-600 font-medium">
                  {event.description.split('\n\n').map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                  <div class="pt-3 border-t border-amber-200">
                    <p>
                      <span class="font-bold text-amber-700">Location:</span> {event.location}
                    </p>
                    <p>
                      <span class="font-bold text-amber-700">Cost:</span> {event.cost}
                      {event.costNote && ` - ${event.costNote}`}
                    </p>
                  </div>
                </div>
              </div>
            </a>
          ))
        ) : (
          <div>
            <p class="text-lg text-stone-600 italic font-medium">
              No upcoming events scheduled.
            </p>
            <p class="text-lg text-stone-600 font-medium mt-4">
              Check back here for updates on classes, open workshop hours, and community events.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Recent Creations Section -->
  <section class="bg-amber-200 py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-8 text-amber-700">
        Recent Creations
      </h2>
      <div class="space-y-12">
        {creations.map((creation) => (
          <article class="grid md:grid-cols-2 gap-8 items-center">
            {creation.images.length > 0 && (
              <div class="creation-carousel relative w-4/5 mx-auto aspect-square" data-carousel>
                {creation.images.map((image, i) => (
                  <div
                    class="absolute inset-0 rounded-full overflow-hidden border border-amber-300 shadow-lg transition-opacity duration-300"
                    data-slide
                    style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${i === 0 ? 2 : 1};`}
                  >
                    <img
                      src={image.src}
                      alt={image.alt}
                      class="w-full h-full object-cover block"
                      loading={i === 0 ? undefined : 'lazy'}
                    />
                  </div>
                ))}
                {creation.images.length > 1 && (
                  <>
                    <button
                      type="button"
                      aria-label="Previous image"
                      class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 hover:bg-white text-amber-700 text-2xl font-bold shadow-md flex items-center justify-center transition z-10"
                      data-prev
                    >&lsaquo;</button>
                    <button
                      type="button"
                      aria-label="Next image"
                      class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 hover:bg-white text-amber-700 text-2xl font-bold shadow-md flex items-center justify-center transition z-10"
                      data-next
                    >&rsaquo;</button>
                  </>
                )}
              </div>
            )}
            <div class="text-lg text-stone-700 font-medium leading-relaxed">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
                <h3 class="text-2xl md:text-3xl font-extrabold text-amber-700">{creation.title}</h3>
                <p class="text-lg font-bold text-amber-600">{formatCreationDate(creation.date)}</p>
              </div>
              <div class="space-y-3">
                {creation.description.split('\n\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Section -->
  <section class="bg-amber-50 py-16 relative overflow-hidden">
    <svg
      class="absolute inset-0 w-full h-full opacity-40 pointer-events-none"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <pattern id="eighties-pattern" x="0" y="0" width="170" height="170" patternUnits="userSpaceOnUse">
          <g fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- hammer (top-left) -->
            <g transform="translate(6,4) scale(0.75)" stroke="#ff3737">
              <path d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9" />
              <path d="m18 15 4-4" />
              <path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5" />
            </g>
            <!-- wrench (rotated, top-middle) -->
            <g transform="translate(62,2) scale(0.78) rotate(25 12 12)" stroke="#ffc193">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z" />
            </g>
            <!-- scissors (top-right) -->
            <g transform="translate(124,4) scale(0.72)" stroke="#ff5d5d">
              <circle cx="6" cy="6" r="3" />
              <path d="M8.12 8.12 12 12" />
              <path d="M20 4 8.12 15.88" />
              <circle cx="6" cy="18" r="3" />
              <path d="M14.8 14.8 20 20" />
            </g>
            <!-- paintbrush (left-middle, tilted) -->
            <g transform="translate(2,46) scale(0.72) rotate(-12 12 12)" stroke="#ff3737">
              <path d="m14.622 17.897-10.68-2.913" />
              <path d="M18.376 2.622a1 1 0 1 1 3.002 3.002L17.36 9.643a.5.5 0 0 0 0 .707l.944.944a2.41 2.41 0 0 1 0 3.408l-.944.944a.5.5 0 0 1-.707 0L8.354 7.348a.5.5 0 0 1 0-.707l.944-.944a2.41 2.41 0 0 1 3.408 0l.944.944a.5.5 0 0 0 .707 0z" />
              <path d="M9 8c-1.804 2.71-3.97 3.46-6.583 3.948a.507.507 0 0 0-.302.819l7.32 8.883a1 1 0 0 0 1.185.204C12.735 20.405 16 16.792 16 15" />
            </g>
            <!-- pencil (middle, angled) -->
            <g transform="translate(58,44) scale(0.7) rotate(22 12 12)" stroke="#ff8383">
              <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z" />
              <path d="m15 5 4 4" />
            </g>
            <!-- ruler (right-middle) -->
            <g transform="translate(112,46) scale(0.75) rotate(-18 12 12)" stroke="#ffc193">
              <path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z" />
              <path d="m14.5 12.5 2-2" />
              <path d="m11.5 9.5 2-2" />
              <path d="m8.5 6.5 2-2" />
              <path d="m17.5 15.5 2-2" />
            </g>
            <!-- palette (left-bottom) -->
            <g transform="translate(4,94) scale(0.78)" stroke="#ff3737" color="#ff3737">
              <path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z" />
              <circle cx="13.5" cy="6.5" r=".5" fill="currentColor" />
              <circle cx="17.5" cy="10.5" r=".5" fill="currentColor" />
              <circle cx="6.5" cy="12.5" r=".5" fill="currentColor" />
              <circle cx="8.5" cy="7.5" r=".5" fill="currentColor" />
            </g>
            <!-- drill (middle-bottom) -->
            <g transform="translate(56,96) scale(0.72)" stroke="#ff5d5d">
              <path d="M10 18a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H5a3 3 0 0 1-3-3 1 1 0 0 1 1-1z" />
              <path d="M13 10H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1l-.81 3.242a1 1 0 0 1-.97.758H8" />
              <path d="M14 4h3a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-3" />
              <path d="M18 6h4" />
              <path d="m5 10-2 8" />
              <path d="m7 18 2-8" />
            </g>
            <!-- axe (right-bottom) -->
            <g transform="translate(114,92) scale(0.78) rotate(-10 12 12)" stroke="#ff3737">
              <path d="m14 12-8.381 8.38a1 1 0 0 1-3.001-3L11 9" />
              <path d="M15 15.5a.5.5 0 0 0 .5.5A6.5 6.5 0 0 0 22 9.5a.5.5 0 0 0-.5-.5h-1.672a2 2 0 0 1-1.414-.586l-5.062-5.062a1.205 1.205 0 0 0-1.704 0L9.352 5.648a1.205 1.205 0 0 0 0 1.704l5.062 5.062A2 2 0 0 1 15 13.828z" />
            </g>
            <!-- sparkles (bottom-left) -->
            <g transform="translate(6,138) scale(0.6)" stroke="#ffc193">
              <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
              <path d="M20 2v4" />
              <path d="M22 4h-4" />
              <circle cx="4" cy="20" r="2" />
            </g>
            <!-- lightbulb (bottom-middle) -->
            <g transform="translate(64,140) scale(0.7)" stroke="#ff3737">
              <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
              <path d="M9 18h6" />
              <path d="M10 22h4" />
            </g>
            <!-- cog (bottom-right) -->
            <g transform="translate(122,138) scale(0.62)" stroke="#ff8383">
              <path d="M11 10.27 7 3.34" />
              <path d="m11 13.73-4 6.93" />
              <path d="M12 22v-2" />
              <path d="M12 2v2" />
              <path d="M14 12h8" />
              <path d="m17 20.66-1-1.73" />
              <path d="m17 3.34-1 1.73" />
              <path d="M2 12h2" />
              <path d="m20.66 17-1.73-1" />
              <path d="m20.66 7-1.73 1" />
              <path d="m3.34 17 1.73-1" />
              <path d="m3.34 7 1.73 1" />
              <circle cx="12" cy="12" r="2" />
              <circle cx="12" cy="12" r="8" />
            </g>
          </g>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#eighties-pattern)"/>
    </svg>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <blockquote class="text-2xl md:text-3xl font-medium text-stone-700 italic leading-relaxed">
        &ldquo;Why are you keeping this curiosity door locked?&rdquo;
      </blockquote>
      <p class="mt-4 text-lg font-semibold text-amber-700">
        &mdash; Dustin Henderson
      </p>
    </div>
  </section>

  <!-- Partners Section -->
  <section class="bg-amber-100 py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-8 text-amber-700">
        Partners
      </h2>
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <img
          src="/images/sewing-machine-project.webp"
          alt="The collection of sewing machines donated by The Sewing Machine Project"
          width="1400"
          height="933"
          loading="lazy"
          class="w-full h-auto rounded-2xl shadow-lg border border-amber-300"
        />
        <div class="text-lg text-stone-700 font-medium leading-relaxed">
          <p>
            <a href="https://thesewingmachineproject.org/" target="_blank" rel="noopener noreferrer" class="font-bold text-amber-700 hover:text-amber-800 underline decoration-amber-400 decoration-2 underline-offset-4 hover:decoration-amber-500 transition-colors duration-300">The Sewing Machine Project</a>
            graciously donated <strong>SIX</strong> (count &lsquo;em, six!) sewing machines and one serger to The Ned Workshop. The Sewing Machine Project lovingly refurbishes sewing machines and makes them available to organizations like ours. We are delighted to share these machines with you at an upcoming class or market. A massive thank you to the entire team at Sewing Machine Project for empowering us to use these machines to create, play, make, and learn!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="bg-amber-300 py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-6 text-amber-700">
        Say Hello!
      </h2>
      <p class="text-xl text-stone-700 font-medium">
        Please <a href="mailto:info@nedworkshop.org" class="font-bold text-amber-700 hover:text-amber-800 underline decoration-amber-400 decoration-2 underline-offset-4 hover:decoration-amber-500 transition-colors duration-300">reach out</a> with any questions! If you have ideas or suggestions for current or future class offerings, feel free to send those our way too!
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-slide]'));
    const prev = carousel.querySelector<HTMLButtonElement>('[data-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-next]');
    if (slides.length === 0) return;
    let index = 0;
    const show = (newIndex: number) => {
      const len = slides.length;
      const wrapped = ((newIndex % len) + len) % len;
      slides.forEach((slide, i) => {
        slide.style.opacity = i === wrapped ? '1' : '0';
        slide.style.zIndex = i === wrapped ? '2' : '1';
      });
      index = wrapped;
    };
    prev?.addEventListener('click', () => show(index - 1));
    next?.addEventListener('click', () => show(index + 1));
  });
</script>
