---
import { GIVEBUTTER_ACCOUNT_ID, GIVEBUTTER_NEWSLETTER_WIDGET_ID } from '../lib/givebutter';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object;
}

const {
  title,
  description = 'Enable the community to repair and create through educational skill building workshops and access to tools.',
  image = '/images/meta-image.jpg',
  type = 'website',
  jsonLd
} = Astro.props;

const siteOrigin = import.meta.env.DEV ? Astro.url.origin : Astro.site;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('The Ned Workshop') ? title : `${title} | The Ned Workshop`;
const ogImage = image.startsWith('http') ? image : new URL(image, siteOrigin).toString();

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "The Ned Workshop",
  "description": "Enable the community to repair and create through educational skill building workshops and access to tools.",
  "url": "https://nedworkshop.org",
  "logo": "https://nedworkshop.org/favicon.svg",
  "email": "info@nedworkshop.org",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nederland",
    "addressRegion": "CO",
    "addressCountry": "US"
  },
  "sameAs": []
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fffbeb" />

    <!-- iOS web-app / home-screen -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Ned Workshop" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="The Ned Workshop" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Caprasimo&display=swap"
    />

    <title>{fullTitle}</title>

    {GIVEBUTTER_ACCOUNT_ID && (
      <script
        is:inline
        defer
        src={`https://widgets.givebutter.com/latest.umd.cjs?acct=${GIVEBUTTER_ACCOUNT_ID}&p=other`}
      />
    )}

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-amber-50 border-b-2 border-amber-200 sticky top-0 z-50 pt-[env(safe-area-inset-top)] pl-[env(safe-area-inset-left)] pr-[env(safe-area-inset-right)]">
      <nav class="max-w-5xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between gap-3">
          <a href="/" class="group min-w-0">
            <span class="text-xl md:text-2xl font-extrabold text-amber-600 group-hover:text-amber-700 transition-colors duration-300 whitespace-nowrap">
              The Ned Workshop
            </span>
          </a>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Home
            </a>
            <a href="/events" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Events
            </a>
            <a href="/tools" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              Tool Library
            </a>
            <a href="/about" class="text-stone-600 hover:text-amber-600 transition-colors font-bold">
              About
            </a>
            <a
              href="https://givebutter.com/f0z0Bm"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 bg-amber-500 hover:bg-amber-600 text-white font-extrabold uppercase tracking-wider text-sm px-4 py-2 rounded-full shadow-md hover:shadow-lg transition-all duration-300"
            >
              <span aria-hidden="true">★</span>
              Donate
            </a>
          </div>

          <!-- Mobile menu toggle -->
          <button
            id="mobile-menu-toggle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="md:hidden flex-shrink-0 p-2 -mr-2 text-amber-700 hover:text-amber-800 transition-colors"
          >
            <svg id="mobile-menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="4" x2="20" y1="6" y2="6"></line>
              <line x1="4" x2="20" y1="12" y2="12"></line>
              <line x1="4" x2="20" y1="18" y2="18"></line>
            </svg>
            <svg id="mobile-menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Mobile menu panel -->
        <div id="mobile-menu" class="md:hidden hidden flex-col gap-1 pt-4 mt-4 border-t border-amber-200">
          <a href="/" class="text-stone-700 hover:text-amber-600 hover:bg-amber-50 transition-colors font-bold py-3 px-2 rounded">
            Home
          </a>
          <a href="/events" class="text-stone-700 hover:text-amber-600 hover:bg-amber-50 transition-colors font-bold py-3 px-2 rounded">
            Events
          </a>
          <a href="/tools" class="text-stone-700 hover:text-amber-600 hover:bg-amber-50 transition-colors font-bold py-3 px-2 rounded">
            Tool Library
          </a>
          <a href="/about" class="text-stone-700 hover:text-amber-600 hover:bg-amber-50 transition-colors font-bold py-3 px-2 rounded">
            About
          </a>
          <a
            href="https://givebutter.com/f0z0Bm"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-1.5 bg-amber-500 hover:bg-amber-600 text-white font-extrabold uppercase tracking-wider text-sm px-4 py-3 mt-1 rounded-full shadow-md transition-all duration-300"
          >
            <span aria-hidden="true">★</span>
            Donate
          </a>
        </div>
      </nav>
      <script is:inline>
        (() => {
          const btn = document.getElementById('mobile-menu-toggle');
          const menu = document.getElementById('mobile-menu');
          const iconOpen = document.getElementById('mobile-menu-icon-open');
          const iconClose = document.getElementById('mobile-menu-icon-close');
          if (!btn || !menu) return;
          btn.addEventListener('click', () => {
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden', isOpen);
            menu.classList.toggle('flex', !isOpen);
            iconOpen.classList.toggle('hidden', !isOpen);
            iconClose.classList.toggle('hidden', isOpen);
            btn.setAttribute('aria-expanded', String(!isOpen));
            btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
          });
        })();
      </script>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-amber-50 border-t-2 border-amber-200 mt-auto pb-[env(safe-area-inset-bottom)] pl-[env(safe-area-inset-left)] pr-[env(safe-area-inset-right)]">
      <div class="max-w-5xl mx-auto px-6 py-8">
        {GIVEBUTTER_NEWSLETTER_WIDGET_ID && (
          <div class="relative w-fit mx-auto mb-8">
            <givebutter-widget id={GIVEBUTTER_NEWSLETTER_WIDGET_ID} class="block"></givebutter-widget>
            <div class="pointer-events-none absolute inset-0 rounded-2xl border-2 border-amber-300"></div>
          </div>
        )}
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-stone-500 text-sm font-semibold">
            &copy; {new Date().getFullYear()} The Ned Workshop
          </p>
          <p class="text-lg font-bold text-amber-600">
            Create, play, make, learn&mdash;together.
          </p>
        </div>
        <div class="text-stone-500 text-sm font-medium text-center mt-6">
          <p>The Ned Workshop is a 501(c)(3) nonprofit (EIN 41-3271935). Donations are tax-deductible to the extent allowed by law.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
