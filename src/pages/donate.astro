---
const target = 'https://givebutter.com/nederland-farmers-market-may-24th-2026-copy-wbord8';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Donate | The Ned Workshop</title>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>&hellip;</p>
  </body>
</html>
