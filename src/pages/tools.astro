---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTools } from '../lib/tools';

const description = "Browse the Ned Workshop Tool Library - sewing machines and more available to rent or borrow.";

const tools = await getTools();

// Group by category
const toolsByCategory = tools.reduce<Record<string, typeof tools>>((acc, tool) => {
  if (!acc[tool.category]) acc[tool.category] = [];
  acc[tool.category].push(tool);
  return acc;
}, {});
---

<BaseLayout title="Tool Library" description={description}>
  <!-- Page Header -->
  <section class="bg-amber-50 py-10">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold text-amber-700">
        Tool Library
      </h1>
      <p class="mt-4 text-xl md:text-2xl text-stone-700 font-semibold">
        A little market of things to borrow.
      </p>
    </div>
  </section>

  {Object.entries(toolsByCategory).map(([category, items], idx) => (
    <section class:list={["py-16", idx % 2 === 0 ? "bg-amber-100" : "bg-amber-200"]}>
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-8 text-amber-700">
          {category}{items.length > 1 ? 's' : ''}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((tool) => (
            <article class="bg-white/80 rounded-2xl overflow-hidden border border-amber-200 hover:border-amber-400 hover:shadow-lg transition-all duration-300 flex flex-col">
              {tool.image && (
                <img
                  src={tool.image.replace(/^\/public/, '')}
                  alt={tool.title}
                  class="w-full aspect-[3/2] object-cover"
                  loading="lazy"
                />
              )}
              <div class="p-5 flex-1 flex flex-col">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <h3 class="text-xl font-extrabold text-amber-700 leading-tight">{tool.title}</h3>
                  {tool.cost && (
                    <span class="shrink-0 bg-amber-500 text-white text-xs font-bold px-2 py-1 rounded-full">{tool.cost}</span>
                  )}
                </div>
                <p class="text-sm font-bold text-stone-500 uppercase tracking-wide mb-3">{tool.brand}</p>
                <p class="text-stone-700 font-medium flex-1">{tool.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>
